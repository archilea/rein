# Rein configuration example.
#
# Copy this file to .env (which is gitignored) and fill in the values:
#   cp .env.example .env
#
# .env is loaded automatically by docker compose and by most shells via
# `set -a; source .env; set +a`. Never commit the real .env file.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Bearer token for the admin API. Anyone with this token can flip the
# kill-switch, mint virtual keys, and revoke them. Treat it like a root secret.
# Generate a fresh one with: openssl rand -hex 32
REIN_ADMIN_TOKEN=

# AES-256 key used to encrypt upstream API keys at rest in the SQLite keystore.
# 32 bytes, hex-encoded (64 hex characters). Rein refuses to start without
# this value when REIN_DB_URL points at a SQLite database, so plaintext
# credentials cannot land on disk by accident.
# Generate a fresh one with: openssl rand -hex 32
# Lose this key and the database becomes unreadable. Back it up like a root secret.
REIN_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Optional (defaults shown)
# -----------------------------------------------------------------------------

# HTTP port Rein listens on.
# REIN_PORT=8080

# Keystore location. Supported schemes:
#   sqlite:<path>   durable on-disk store, AES-256-GCM encrypted at rest
#   memory          in-memory store, cleared on restart (tests / ephemeral use)
# REIN_DB_URL=sqlite:./rein.db

# Upstream base URLs. Override these to point Rein at a staging upstream,
# a local mock, or a sibling gateway that speaks the OpenAI or Anthropic API.
# REIN_OPENAI_BASE=https://api.openai.com
# REIN_ANTHROPIC_BASE=https://api.anthropic.com
